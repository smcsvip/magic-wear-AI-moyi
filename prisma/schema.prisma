generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int           @id @default(autoincrement())
  username         String        @unique
  email            String?       @unique // 邮箱，可空（老用户），不能重复
  emailUpdatedAt   DateTime?     @map("email_updated_at") // 邮箱最后修改时间，用于 7 天限制
  emailSubscribed  Boolean       @default(true) @map("email_subscribed") // 是否订阅每日邮件，默认订阅
  password         String
  nickname         String?       // 昵称，可空，未设置时前端显示用户名
  avatar           String?       @db.Text // 头像，base64 字符串，可空
  createdAt        DateTime      @default(now()) @map("created_at")
  records          TryonRecord[]

  @@map("users")
}

model TryonRecord {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  resultImage String   @map("result_image")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tryon_records")
}

model EmailVerification {
  id        Int      @id @default(autoincrement())
  email     String   // 邮箱地址
  code      String   // 6 位验证码
  expiresAt DateTime @map("expires_at") // 过期时间
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, expiresAt]) // 加索引提升查询速度
  @@map("email_verifications")
}

model Feedback {
  id        Int      @id @default(autoincrement())
  type      String   // 反馈类型：bug, feature, other
  content   String   @db.Text // 反馈内容
  email     String?  // 联系邮箱（可选）
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feedbacks")
}

