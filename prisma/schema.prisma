generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int           @id @default(autoincrement())
  username        String        @unique
  email           String?       @unique
  emailUpdatedAt  DateTime?     @map("email_updated_at")
  emailSubscribed Boolean       @default(true) @map("email_subscribed")
  password        String
  nickname        String?
  avatar          String?       @db.Text
  role            String        @default("user")
  status          String        @default("active")
  createdAt       DateTime      @default(now()) @map("created_at")
  records         TryonRecord[]

  @@map("users")
}

model TryonRecord {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  resultImage String   @map("result_image")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tryon_records")
}

model EmailVerification {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, expiresAt])
  @@map("email_verifications")
}

model Feedback {
  id        Int      @id @default(autoincrement())
  type      String
  content   String   @db.Text
  email     String?
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feedbacks")
}

// 系统配置表：存储全局系统设置
model SystemConfig {
  id                 Int      @id @default(autoincrement())
  maintenanceMode    Boolean  @default(false) @map("maintenance_mode") // 维护模式开关
  maintenanceMessage String?  @db.Text @map("maintenance_message") // 维护提示信息
  updatedAt          DateTime @updatedAt @map("updated_at") // 最后更新时间

  @@map("system_configs")
}
